<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Layer classifications"
        Width="640" Height="540" MinWidth="560" MinHeight="440"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="White">
    <Grid Margin="14,12,14,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Foreground="#666666"
                   Margin="0,0,0,8"
                   Text="Each layer becomes a piping system named exactly like it. The classification below decides which donor system type it duplicates - pre-filled automatically from the layer name; select rows, pick a classification and 'Assign to selected' to override."/>

        <ListView Grid.Row="1" x:Name="LstRows" SelectionMode="Extended">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Layer"          Width="300" DisplayMemberBinding="{Binding [layer]}"/>
                    <GridViewColumn Header="Classification" Width="240" DisplayMemberBinding="{Binding [value]}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <DockPanel Grid.Row="2" Margin="0,8,0,0">
            <Button DockPanel.Dock="Right" Content="Assign to selected"
                    MinWidth="120" Margin="8,3,0,0" Padding="8,2"
                    Click="on_assign"/>
            <ComboBox x:Name="CmbValue" Height="24" Margin="0,3,0,0"/>
        </DockPanel>

        <Border Grid.Row="3" BorderThickness="0,1,0,0" BorderBrush="#DDDDDD"
                Background="#F5F5F5" Margin="-14,10,-14,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="14,10">
                <Button Content="OK" IsDefault="True" MinWidth="96"
                        Margin="8,0,0,0" Padding="10,4" Click="on_ok"/>
                <Button Content="Cancel" MinWidth="96" Margin="8,0,0,0"
                        Padding="10,4" Click="on_cancel"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
