<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Place Structures"
        Width="900" Height="640" MinWidth="820" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="White">
    <Window.Resources>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="10,8,10,10"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,6,10,0"/>
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="SideButton" TargetType="Button">
            <Setter Property="MinWidth" Value="88"/>
            <Setter Property="Margin" Value="8,3,0,0"/>
            <Setter Property="Padding" Value="8,2"/>
        </Style>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- export row -->
        <GroupBox Grid.Row="0" Header="Dashboard export" Margin="14,12,14,0">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Browse..."
                        Style="{StaticResource SideButton}" Click="on_browse"/>
                <TextBox x:Name="TxtExport" Height="24" IsReadOnly="True"
                         VerticalContentAlignment="Center" Margin="0,3,0,0"/>
            </DockPanel>
        </GroupBox>

        <!-- body -->
        <Grid Grid.Row="1" Margin="14,10,14,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="330"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Layers to place" Margin="0,0,10,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom">
                        <DockPanel Margin="0,8,0,0">
                            <TextBlock Text="Workset" Style="{StaticResource FieldLabel}"/>
                            <Button DockPanel.Dock="Right" Content="Assign to selected"
                                    Style="{StaticResource SideButton}" Click="on_assign_ws"/>
                            <ComboBox x:Name="CmbWorkset"/>
                        </DockPanel>
                        <TextBlock Style="{StaticResource Hint}"
                                   Text="Highlighted rows are placed (all selected after loading). Pick a workset and 'Assign to selected' to map rows; the map is remembered and pre-filled from the export / previous runs."/>
                    </StackPanel>
                    <ListView x:Name="LstLayers" SelectionMode="Extended">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Layer"   Width="240" DisplayMemberBinding="{Binding [layer]}"/>
                                <GridViewColumn Header="Box"     Width="52"  DisplayMemberBinding="{Binding [box]}"/>
                                <GridViewColumn Header="Cyl"     Width="52"  DisplayMemberBinding="{Binding [cyl]}"/>
                                <GridViewColumn Header="Workset" Width="150" DisplayMemberBinding="{Binding [workset]}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </GroupBox>

            <StackPanel Grid.Column="1">
                <GroupBox Header="Family for BOX chambers">
                    <StackPanel>
                        <TextBlock Text="Category" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbBoxCat" SelectionChanged="on_box_cat_changed"/>
                        <TextBlock Text="Family : Type" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbBoxFam" SelectionChanged="on_box_fam_changed"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="86"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="L (length)" Style="{StaticResource FieldLabel}"/>
                            <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="CmbBoxL"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="W (width)" Style="{StaticResource FieldLabel}"/>
                            <ComboBox  Grid.Row="1" Grid.Column="1" x:Name="CmbBoxW"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="H (depth)" Style="{StaticResource FieldLabel}"/>
                            <ComboBox  Grid.Row="2" Grid.Column="1" x:Name="CmbBoxH"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Origin" Style="{StaticResource FieldLabel}"/>
                            <ComboBox  Grid.Row="3" Grid.Column="1" x:Name="CmbBoxOrigin"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>
                <GroupBox Header="Family for CYLINDRICAL chambers">
                    <StackPanel>
                        <TextBlock Text="Category" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbCylCat" SelectionChanged="on_cyl_cat_changed"/>
                        <TextBlock Text="Family : Type" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbCylFam" SelectionChanged="on_cyl_fam_changed"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="86"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="DIA" Style="{StaticResource FieldLabel}"/>
                            <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="CmbCylDia"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="H (depth)" Style="{StaticResource FieldLabel}"/>
                            <ComboBox  Grid.Row="1" Grid.Column="1" x:Name="CmbCylH"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Origin" Style="{StaticResource FieldLabel}"/>
                            <ComboBox  Grid.Row="2" Grid.Column="1" x:Name="CmbCylOrigin"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>
                <Button x:Name="BtnLoadRfa" Content="Load a family (.rfa)..."
                        MinWidth="150" Padding="8,3" HorizontalAlignment="Left"
                        Click="on_load_rfa"/>
                <GroupBox Header="Options" Margin="0,12,0,0">
                    <StackPanel>
                        <CheckBox x:Name="ChkSystemType" IsChecked="True" Margin="0,4,0,2"
                                  Content="Assign the layer-named piping system type"/>
                        <TextBlock Style="{StaticResource Hint}"
                                   Text="Same automation as the pipes: each instance gets the piping system type named exactly like its layer (created by Project Setup). Families that expose no writable system parameter are reported, not failed."/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </Grid>

        <!-- bottom bar -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#DDDDDD"
                Background="#F5F5F5" Margin="0,10,0,0">
            <DockPanel Margin="14,10">
                <TextBlock x:Name="StatusText" DockPanel.Dock="Left"
                           VerticalAlignment="Center" Foreground="#666666"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Place" IsDefault="True"
                            Style="{StaticResource DialogButton}" Click="on_place"/>
                    <Button Content="Cancel" Style="{StaticResource DialogButton}"
                            Click="on_cancel"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
